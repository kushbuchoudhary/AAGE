# ── AAGE Backend Environment Variables ──
PORT=5000
CLIENT_URL=http://localhost:3000

# MongoDB connection string
# For local: mongodb://localhost:27017/aage
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/aage
MONGODB_URI=mongodb://localhost:27017/aage

# JWT secret (change this in production!)
JWT_SECRET=aage_super_secret_key_change_me_in_production

# Optional: Node environment
NODE_ENV=development
